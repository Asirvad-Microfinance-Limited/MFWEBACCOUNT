

@{
    ViewData["Title"] = "AGREEMENT_UPDATIONT";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header"><strong>AGREEMENT UPDATION</strong></div>
            <div class="card-body card-block">
                <form name="frmAddAgreement" id="frmAddAgreement" method="post">

                    <div class="row form-group">

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Select Branch<b style="color:red">*</b></label>
                                <select name="ddlbranch" id="ddlbranch" class="form-control">
                                    <option value="0">--Select--</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1"> Select Category<b style="color:red">*</b></label>
                                <select name="ddlcategory" id="ddlCategory" class="form-control">
                                    <option value="0">--Select--</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1"> Select Building<b style="color:red">*</b></label>
                                <select name="ddlcategory" id="ddlbuilding" class="form-control">
                                    <option value="0">--Select--</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">

                                <label for="cc-payment" class="control-label mb-1">Rent Period In Months</label>
                                <input type="text" id="TxtrentPeriod" name="Rent Period" placeholder="0" class="form-control" disabled> 

                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">

                                <label for="cc-payment" class="control-label mb-1">Enhancement Period In Months</label>
                                <input type="text" id="TxtEnhcePeriod"  name="Enhancement Period in Months" placeholder="0" class="form-control" disabled>

                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container1">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Advance Paid Date </label>
                                <input type="text" id="TxtAdvncPaiddt" name="Advance Paid Date" class="form-control" placeholder="DD/MM/YYYY" disabled />
                            </div>
                        </div>
                       @*   <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" >
                           
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" i>
                           
                        </div> *@
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container2">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Agreement Date<b style="color:red">*</b></label>
                                <input type="text" id="TxtAgrmtDt" name="Enter AgreementDate" class="form-control" placeholder="DD/MM/YYYY" onkeypress="return false" />
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container3">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Effective Date (First Rent)<b style="color:red">*</b></label>
                                <input type="text" id="TxtEffectiveDt" name="Effective Date" class="form-control" placeholder="DD/MM/YYYY" onkeypress="return false" />
                            </div>
                        </div>

                          <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container4">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Next Enhancement Date</label>
                                <input type="text" id="TxtNextEnhancementDat" name="Next Enhancement Date" class="form-control" placeholder="DD/MM/YYYY" disabled />
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container5">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Agreement End Date</label>
                                <input type="text" id="TxtAgreementEndDt" name="Agreement End Date" class="form-control" placeholder="DD/MM/YYYY" disabled/>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container6">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Inauguration Date<b style="color:red">*</b></label>
                                <input type="text" id="TxtInaugurationDt" name="Inauguration Date" class="form-control" placeholder="DD/MM/YYYY" onkeypress="return false" />
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12" id="bs_datepicker_container7">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Work Completion Date<b style="color:red">*</b></label>
                                <input type="text" id="TxtWorkCompletionDt" name="Work Completion Date" class="form-control" placeholder="DD/MM/YYYY" onkeypress="return false" />
                            </div>
                        </div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <div class="form-check" style="margin-top: 35px;">
                                    <input type="checkbox" class="form-check-input" id="chkRentPaid" value="F" onclick="updateCheckboxValue(this)">
                                    <label class="form-check-label" for="chkAgreement">
                                        Tick Whether Rent Paid in Advance in All Months
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>


                </form>

                <div class="text-right" id="confirmbutton">
                    <div class="text-right" style="padding: 10px">
                        <button type="button" class="btn btn-success action-btn" id="BtnConfirm">Confirm</button>
                        <button type="button" class="btn btn-danger action-btn" id="btn_exit">EXIT</button>


                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

<style>
    .action-btn {
        width: 85px;
        margin-left: 3px;
    }

    .btn-custom {
        background-color: #dee2e6;
        color: #000;
        border: 1px solid #ccc;
    }
</style>


@section Scripts {

    <script src="~/clientapp/addagreement/aggriment_updation.js"></script>


}

